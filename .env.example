# aivm environment configuration
# Copy to .env and fill in required values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# REQUIRED — set before first use
# ──────────────────────────────────────────────

# Long-lived OAuth token for Claude Code. Generate it on your host with:
#   claude setup-token
# Then paste the token below.
CLAUDE_CODE_OAUTH_TOKEN=REPLACE_ME

# ──────────────────────────────────────────────
# Colima VM settings
# ──────────────────────────────────────────────

# Colima profile name (do not change unless you know what you're doing)
AIVM_COLIMA_PROFILE=aivm

# VM resources
AIVM_VM_CPUS=4
AIVM_VM_MEMORY=8      # GiB
AIVM_VM_DISK=60       # GiB

# VM type: vz (Apple Silicon, fast) or qemu (Intel/fallback)
AIVM_VM_TYPE=vz

# Maximum VM age in days before prompting to recreate (interactive mode only)
AIVM_VM_MAX_AGE_DAYS=7

# ──────────────────────────────────────────────
# Path mapping
# ──────────────────────────────────────────────

# Host dev root — MUST be an absolute path; ~ is expanded at runtime
AIVM_DEV_ROOT=~/dev

# ──────────────────────────────────────────────
# MCPJungle settings
# ──────────────────────────────────────────────

MCPJUNGLE_PORT=8080
MCPJUNGLE_DATA_DIR=~/.aivm/mcpjungle-data
MCPJUNGLE_SERVER_MODE=development
MCPJUNGLE_IMAGE_TAG=latest-stdio

# ──────────────────────────────────────────────
# Idle monitor
# ──────────────────────────────────────────────

# Idle timeout in seconds before auto-shutdown (default: 300 = 5 minutes)
AIVM_IDLE_TIMEOUT=300

# ──────────────────────────────────────────────
# Backend Skills Plugin — AWS credentials
# ──────────────────────────────────────────────
# Dedicated limited-permission IAM user for the backend-skills-plugin MCP server.
# DO NOT use your personal AWS credentials here.
#
# Required IAM policy:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": "secretsmanager:GetSecretValue",
#       "Resource": [
#         "arn:aws:secretsmanager:us-east-1:*:secret:touchtunes/oracle/*",
#         "arn:aws:secretsmanager:us-east-1:*:secret:touchtunes/mysql/*",
#         "arn:aws:secretsmanager:us-east-1:*:secret:touchtunes/documentdb/*",
#         "arn:aws:secretsmanager:us-east-1:*:secret:touchtunes/catalog/bedrock*"
#       ]
#     },
#     {
#       "Effect": "Allow",
#       "Action": ["s3:GetObject", "s3:ListBucket"],
#       "Resource": [
#         "arn:aws:s3:::tt-catalog-store",
#         "arn:aws:s3:::tt-catalog-store/*"
#       ]
#     },
#     {
#       "Effect": "Allow",
#       "Action": "s3:GetObject",
#       "Resource": "arn:aws:s3:::tt-platform/cursor-plugin/oracle-instant-client/*"
#     }
#   ]
# }
BSP_AWS_ACCESS_KEY_ID=
BSP_AWS_SECRET_ACCESS_KEY=
BSP_AWS_REGION=us-east-1

# ──────────────────────────────────────────────
# Debug
# ──────────────────────────────────────────────
# AIVM_DEBUG=1
